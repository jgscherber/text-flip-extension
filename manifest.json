{
  "manifest_version": 3,
  "name": "Text Flip",
  "version": "1.0.0",
  "description": "Toggle alternating flipped text on any page",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js",
    "scripts": ["background/background.js"]
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "browser_specific_settings": {
    "gecko": {
      "id": "text-flip@extension",
      "strict_min_version": "109.0"
    }
  }
}
